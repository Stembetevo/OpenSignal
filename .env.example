PORT=10000
NODE_ENV=development
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SPONSOR_PRIVATE_KEY=suiprivkey...
# Optional: if omitted, derived from private key
SPONSOR_ADDRESS=
# Format: dappName:apiKey,dappName2:apiKey2
API_KEYS=demo:change-me
# Set true to allow any Move call (high risk for sponsor funds)
ALLOW_ALL_TRANSACTIONS=false
# Format: package::module::function,package::module::function
# Optional when ALLOW_ALL_TRANSACTIONS=true
ALLOWLIST=0x2::pay::split
MAX_GAS_BUDGET=20000000
DAPP_DAILY_BUDGET_MIST=500000000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
TRUST_PROXY=false
